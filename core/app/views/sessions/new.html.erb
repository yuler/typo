<div class="bg-surface p-6 rounded-xl border shadow-sm w-full max-w-sm text-center">
  <h1 class="text-xl font-bold mb-2">Sign in to Typo</h1>
  <p class="text-muted text-sm mb-6">Enter your email to receive a magic link.</p>

  <%= form_with url: session_path, class: "flex flex-col gap-4" do |form| %>
    <%= form.email_field :email, required: true, autofocus: true, 
        class: "p-2 border rounded-md w-full", placeholder: "email@example.com" %>
    <%= form.submit "Continue", 
        class: "p-2 bg-zinc-900 text-white rounded-md font-medium cursor-pointer" %>
  <% end %>
</div>
