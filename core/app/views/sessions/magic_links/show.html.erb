<div class="bg-surface p-6 rounded-xl border shadow-sm w-full max-w-sm text-center">
  <div class="mb-6 flex justify-center">
    <!-- Simple Mail Icon Placeholder -->
    <div class="p-3 bg-zinc-100 rounded-full text-muted">
       <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-6 h-6"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
    </div>
  </div>

  <h1 class="text-xl font-bold mb-2">Check your email</h1>
  <p class="text-muted text-sm mb-6">We've sent a 6-character code to your inbox.</p>

  <%= form_with url: session_magic_link_path, method: :post, class: "flex flex-col gap-4" do |form| %>
    <%= form.text_field :code, required: true, autofocus: true, maxlength: "6",
        class: "p-2 border rounded-md w-full text-center font-mono text-lg tracking-widest", 
        placeholder: "••••••" %>
    <%= form.submit "Verify Code", 
        class: "p-2 bg-zinc-900 text-white rounded-md font-medium cursor-pointer" %>
  <% end %>
</div>
