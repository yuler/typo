# Desktop app signing key
TAURI_SIGNING_PRIVATE_KEY=~/.tauri/typo.key
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Repo root `.env` — www static deploy (`scripts/www-deploy.sh`; uses rsync over SSH, no password in env)
WWW_SERVER_HOST=
WWW_SERVER_HOST_USERNAME=
WWW_SERVER_HOST_TARGET=
# Optional non-default key (otherwise ssh-agent / default identities)
# WWW_SERVER_SSH_IDENTITY=~/.ssh/id_ed25519
