---
import { localeFlags, localeNames, locales } from '@typo/languages'
import { getLocalizedPath } from '@/lib/i18n'
import LanguageDropdown from './LanguageDropdown.tsx'

const { locale: current, tr } = Astro.locals

const items = locales.map((l) => ({
  code: l,
  name: localeNames[l],
  flag: localeFlags[l],
  href: getLocalizedPath(Astro.url.pathname, l),
  active: l === current,
}))
---

<LanguageDropdown client:load items={items} ariaLabel={tr('header.switcher_aria')} />
