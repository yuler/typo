---
import { getLocale, getLocalizedPath } from '@/lib/i18n'

const { t } = Astro.locals
const locale = getLocale(Astro.currentLocale)

type Testimonial = {
  quote: string
  name: string
  role: string
  /** Optional avatar URL under `public/` (e.g. `/testimonials/yuler.png`). */
  image?: string
}

const items: Testimonial[] = [
  {
    quote: t('testimonials.quote.yuler'),
    name: 'Yuler',
    role: t('testimonials.role.creator'),
    image: '/testimonials/yuler.png',
  },
  {
    quote: t('testimonials.quote.jianwu'),
    name: 'JianWu',
    role: t('testimonials.role.co_founder'),
    image: '/testimonials/jianwu.png',
  },
  {
    quote: t('testimonials.quote.gonghui'),
    name: 'GongHui',
    role: t('testimonials.role.co_founder'),
    image: '/testimonials/gonghui.png',
  },
]

const downloadLink = `<a href="https://github.com/yuler/typo/releases" class="font-medium text-zinc-900 underline decoration-zinc-300 underline-offset-2 transition hover:decoration-zinc-500 dark:text-zinc-100 dark:decoration-zinc-600 dark:hover:decoration-zinc-400">${t('testimonials.download')}</a>`

const docsLink = `<a href="${getLocalizedPath('/docs/getting-started', locale)}" class="font-medium text-zinc-900 underline decoration-zinc-300 underline-offset-2 transition hover:decoration-zinc-500 dark:text-zinc-100 dark:decoration-zinc-600 dark:hover:decoration-zinc-400">${t('testimonials.docs')}</a>`

const descriptionHTML = t('testimonials.description', {
  download: downloadLink,
  docs: docsLink,
})
---

<section class="w-full py-16">
  <div class="mx-auto max-w-5xl px-4 text-center sm:px-6">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500 dark:text-zinc-400">
      {t('testimonials.tag')}
    </p>
    <h2 class="mt-3 text-2xl font-bold tracking-tight text-zinc-900 sm:text-3xl dark:text-zinc-50">
      {t('testimonials.title')}
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-sm text-zinc-600 dark:text-zinc-400" set:html={descriptionHTML} />
  </div>

  <!-- Quotes: one column on small screens, two columns on tablet, one row on large screens -->
  <div class="mt-10 mx-auto max-w-6xl px-4 sm:mt-12 sm:px-6" role="region" aria-label="Testimonials">
    <ul class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-8 md:items-stretch lg:grid-cols-3 lg:gap-6">
      {
        items.map(({ quote, name, role, image }) => (
          <li class="flex min-h-0 w-full">
            <div class="flex h-full min-h-[11rem] w-full flex-col rounded-xl border border-zinc-200 bg-zinc-50/90 p-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-950/60 sm:min-h-[12rem] sm:p-5">
              <blockquote class="flex flex-1 flex-col">
                <span class="text-2xl leading-none text-zinc-300 dark:text-zinc-600" aria-hidden="true">
                  &ldquo;
                </span>
                <p class="mt-1.5 flex-1 text-sm leading-relaxed text-zinc-700 dark:text-zinc-300">{quote}</p>
                <footer class="mt-4 flex items-center gap-2.5 border-t border-zinc-200/80 pt-3 dark:border-zinc-800/80">
                  {image ? (
                    <img
                      src={image}
                      alt={name}
                      width="36"
                      height="36"
                      loading="lazy"
                      decoding="async"
                      class="h-9 w-9 shrink-0 rounded-full object-cover ring-1 ring-zinc-200/90 dark:ring-zinc-700/90"
                    />
                  ) : (
                    <span
                      class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-zinc-200 to-zinc-300 text-[0.65rem] font-bold text-zinc-700 dark:from-zinc-700 dark:to-zinc-600 dark:text-zinc-100"
                      aria-hidden="true"
                    >
                      {name
                        .split(/\s+/)
                        .map((w) => w[0])
                        .join('')
                        .slice(0, 2)
                        .toUpperCase()}
                    </span>
                  )}
                  <div>
                    <cite class="not-italic text-sm font-semibold text-zinc-900 dark:text-zinc-50">{name}</cite>
                    <p class="text-xs text-zinc-500 dark:text-zinc-400">{role}</p>
                  </div>
                </footer>
              </blockquote>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
