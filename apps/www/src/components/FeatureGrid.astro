---
const features = [
  {
    title: 'Multi-model support',
    body: 'Works with DeepSeek and local Ollama models so you can choose cloud or on-device AI.',
    emoji: '🌐',
    tint: 'from-violet-500/25 to-fuchsia-500/20',
  },
  {
    title: 'Global hotkeys',
    body: 'Quick activation with Ctrl/Cmd + Shift + X (or your system shortcut on Wayland).',
    emoji: '⌨️',
    tint: 'from-sky-500/25 to-cyan-400/20',
  },
  {
    title: 'Intelligent pasting',
    body: 'Clipboard-based replacement for maximum compatibility across apps and input methods.',
    emoji: '📋',
    tint: 'from-emerald-500/25 to-teal-400/20',
  },
  {
    title: 'Customizable',
    body: 'Tailor AI behavior via system prompts and up to five prompt shortcuts in Settings.',
    emoji: '⚙️',
    tint: 'from-amber-500/25 to-orange-400/20',
  },
] as const

const [primary, ...rest] = features

const iconSlot =
  'inline-flex size-12 shrink-0 items-center justify-center rounded-xl border border-zinc-200/80 bg-zinc-50 text-2xl shadow-sm dark:border-zinc-700/80 dark:bg-zinc-900/80'
---

<section class="relative overflow-hidden border-y border-zinc-200 py-12 sm:py-16 lg:py-20 dark:border-zinc-800">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(120,119,198,0.15),transparent)] dark:bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(99,102,241,0.12),transparent)]"
    aria-hidden="true"
  >
  </div>
  <div class="relative mx-auto max-w-5xl px-4 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500 dark:text-zinc-400">Workflow</p>
      <h2 class="mt-3 text-2xl font-bold tracking-tight text-zinc-900 sm:text-3xl lg:text-4xl dark:text-zinc-50">
        Built for fast text workflows
      </h2>
      <p class="mt-3 text-pretty text-sm leading-relaxed text-zinc-600 sm:text-base dark:text-zinc-400">
        typo stays out of your way until you need it — then it captures selection, runs your prompt, and pastes the
        result.
      </p>
    </div>

    <!-- Mobile: 1 col · Tablet (sm+): 2 cols, spotlight full-width · Desktop (lg+): 12-col bento -->
    <div class="mt-10 grid grid-cols-1 gap-4 sm:mt-12 sm:grid-cols-2 sm:gap-5 lg:mt-14 lg:grid-cols-12 lg:gap-5">
      <article
        class="group relative flex min-h-0 flex-col justify-between overflow-hidden rounded-2xl border border-zinc-200/80 bg-white/90 p-6 shadow-sm backdrop-blur-sm transition hover:border-zinc-300 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-950/80 dark:hover:border-zinc-700 sm:col-span-2 lg:col-span-7 lg:row-span-2 lg:min-h-[260px] lg:p-8 xl:min-h-[280px]"
      >
        <div
          class:list={[
            'absolute -right-12 -top-12 h-40 w-40 rounded-full opacity-30 blur-3xl transition group-hover:opacity-40 dark:opacity-20 sm:h-48 sm:w-48 sm:-right-16 sm:-top-16',
            'bg-gradient-to-br',
            primary.tint,
          ]}
          aria-hidden="true"
        >
        </div>
        <div>
          <span class:list={[iconSlot]} role="img" aria-hidden="true">{primary.emoji}</span>
          <h3 class="mt-5 text-lg font-semibold tracking-tight text-zinc-900 sm:text-xl dark:text-zinc-50">
            {primary.title}
          </h3>
          <p class="mt-2 max-w-none text-sm leading-relaxed text-zinc-600 sm:mt-3 sm:max-w-md dark:text-zinc-400">
            {primary.body}
          </p>
        </div>
        <p class="mt-6 text-xs font-medium uppercase tracking-wider text-zinc-400 dark:text-zinc-500 lg:mt-8">
          Core capability
        </p>
      </article>

      <article
        class="group relative overflow-hidden rounded-2xl border border-zinc-200/80 bg-white/90 p-5 shadow-sm backdrop-blur-sm transition hover:border-zinc-300 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-950/80 dark:hover:border-zinc-700 sm:p-6 lg:col-span-5 lg:col-start-8 lg:row-start-1"
      >
        <div
          class:list={[
            'pointer-events-none absolute -right-8 -top-8 h-28 w-28 rounded-full opacity-25 blur-2xl dark:opacity-15',
            'bg-gradient-to-br',
            rest[0].tint,
          ]}
          aria-hidden="true"
        >
        </div>
        <span class:list={[iconSlot, 'relative']} role="img" aria-hidden="true">{rest[0].emoji}</span>
        <h3 class="relative mt-4 text-base font-semibold text-zinc-900 sm:text-lg dark:text-zinc-50">
          {rest[0].title}
        </h3>
        <p class="relative mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{rest[0].body}</p>
      </article>

      <article
        class="group relative overflow-hidden rounded-2xl border border-zinc-200/80 bg-white/90 p-5 shadow-sm backdrop-blur-sm transition hover:border-zinc-300 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-950/80 dark:hover:border-zinc-700 sm:p-6 lg:col-span-5 lg:col-start-8 lg:row-start-2"
      >
        <div
          class:list={[
            'pointer-events-none absolute -right-8 -top-8 h-28 w-28 rounded-full opacity-25 blur-2xl dark:opacity-15',
            'bg-gradient-to-br',
            rest[1].tint,
          ]}
          aria-hidden="true"
        >
        </div>
        <span class:list={[iconSlot, 'relative']} role="img" aria-hidden="true">{rest[1].emoji}</span>
        <h3 class="relative mt-4 text-base font-semibold text-zinc-900 sm:text-lg dark:text-zinc-50">
          {rest[1].title}
        </h3>
        <p class="relative mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{rest[1].body}</p>
      </article>

      <article
        class="group relative flex flex-col gap-4 overflow-hidden rounded-2xl border border-zinc-200/80 bg-white/90 p-5 shadow-sm backdrop-blur-sm transition hover:border-zinc-300 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-950/80 dark:hover:border-zinc-700 sm:col-span-2 sm:p-6 lg:col-span-12 lg:flex-row lg:items-stretch lg:gap-8 lg:p-8"
      >
        <div
          class:list={[
            'pointer-events-none absolute -right-10 -top-10 h-36 w-36 rounded-full opacity-25 blur-2xl dark:opacity-15',
            'bg-gradient-to-br',
            rest[2].tint,
          ]}
          aria-hidden="true"
        >
        </div>
        <div class="relative flex flex-col gap-1 lg:w-[min(100%,20rem)] lg:shrink-0">
          <span class:list={[iconSlot]} role="img" aria-hidden="true">{rest[2].emoji}</span>
          <h3 class="mt-3 text-base font-semibold text-zinc-900 sm:text-lg lg:mt-4 dark:text-zinc-50">
            {rest[2].title}
          </h3>
        </div>
        <p class="relative text-sm leading-relaxed text-zinc-600 dark:text-zinc-400 lg:flex-1 lg:self-center lg:pt-1">
          {rest[2].body}
        </p>
      </article>
    </div>
  </div>
</section>
