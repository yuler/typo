---
interface Props {
  variant?: 'blog' | 'docs'
  class?: string
}

const { variant = 'blog', class: className } = Astro.props

const blogProse = [
  '[&_h1]:mb-4 [&_h1]:text-3xl [&_h1]:font-bold [&_h1]:text-zinc-900 dark:[&_h1]:text-zinc-50',
  '[&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:text-zinc-900 dark:[&_h2]:text-zinc-50',
  '[&_h3]:mt-6 [&_h3]:mb-2 [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:text-zinc-900 dark:[&_h3]:text-zinc-50',
  '[&_p]:leading-relaxed [&_p]:text-zinc-600 dark:[&_p]:text-zinc-300',
  '[&_li]:leading-relaxed [&_li]:text-zinc-600 dark:[&_li]:text-zinc-300',
  '[&_ol]:my-3 [&_ol]:pl-5 [&_ul]:my-3 [&_ul]:pl-5',
  '[&_a]:font-medium [&_a]:text-zinc-900 [&_a]:underline [&_a]:underline-offset-2 dark:[&_a]:text-zinc-100',
  '[&_pre]:my-4 [&_pre]:overflow-x-auto [&_pre]:rounded-lg [&_pre]:border [&_pre]:border-zinc-200 [&_pre]:!bg-transparent [&_pre]:p-4 [&_pre]:text-sm dark:[&_pre]:border-zinc-600',
  '[&_code]:rounded [&_code]:border [&_code]:border-zinc-300/90 [&_code]:bg-zinc-200/70 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:font-mono [&_code]:text-[0.875em] [&_code]:text-zinc-900 dark:[&_code]:border-zinc-600 dark:[&_code]:bg-zinc-800/80 dark:[&_code]:text-zinc-200',
  '[&_pre_code]:border-0 [&_pre_code]:!bg-transparent [&_pre_code]:p-0 [&_pre_code]:font-mono [&_pre_code]:text-inherit',
].join(' ')

const docsProse = [
  '[&_h1]:mb-4 [&_h1]:text-4xl [&_h1]:font-bold [&_h1]:leading-tight [&_h1]:tracking-tight [&_h1]:text-zinc-900 dark:[&_h1]:text-zinc-50',
  '[&_h2]:mt-12 [&_h2]:mb-3 [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h2]:text-zinc-900 dark:[&_h2]:text-zinc-50',
  '[&_h3]:mt-8 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-zinc-900 dark:[&_h3]:text-zinc-50',
  '[&_p]:text-base [&_p]:leading-8 [&_p]:text-zinc-600 dark:[&_p]:text-zinc-300',
  '[&_li]:my-1.5 [&_li]:text-base [&_li]:leading-8 [&_li]:text-zinc-600 dark:[&_li]:text-zinc-300',
  '[&_ol]:my-4 [&_ol]:pl-6 [&_ul]:my-4 [&_ul]:pl-6',
  '[&_a]:font-medium [&_a]:text-zinc-800 [&_a]:no-underline [&_a]:decoration-zinc-300 [&_a]:underline-offset-2 [&_a]:transition-colors hover:[&_a]:text-zinc-950 hover:[&_a]:underline dark:[&_a]:text-zinc-200 dark:[&_a]:decoration-zinc-600 dark:hover:[&_a]:text-white',
  '[&_pre]:my-5 [&_pre]:overflow-x-auto [&_pre]:rounded-lg [&_pre]:border [&_pre]:border-zinc-200 [&_pre]:!bg-transparent [&_pre]:p-4 [&_pre]:text-sm dark:[&_pre]:border-zinc-600',
  '[&_code]:rounded [&_code]:border [&_code]:border-zinc-300/90 [&_code]:bg-zinc-200/70 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:font-mono [&_code]:text-[0.875em] [&_code]:font-normal [&_code]:text-zinc-900 dark:[&_code]:border-zinc-600 dark:[&_code]:bg-zinc-800/80 dark:[&_code]:text-zinc-200',
  '[&_pre_code]:border-0 [&_pre_code]:!bg-transparent [&_pre_code]:p-0 [&_pre_code]:font-mono [&_pre_code]:font-normal [&_pre_code]:text-inherit [&_pre_code]:shadow-none',
  '[&_blockquote]:my-4 [&_blockquote]:border-l-4 [&_blockquote]:border-zinc-300 [&_blockquote]:pl-4 [&_blockquote]:text-zinc-600 [&_blockquote]:italic dark:[&_blockquote]:border-zinc-600 dark:[&_blockquote]:text-zinc-300',
].join(' ')

const proseClass = variant === 'docs' ? docsProse : blogProse
---

<div class:list={['mdx-prose', proseClass, className]}>
  <slot />
</div>
