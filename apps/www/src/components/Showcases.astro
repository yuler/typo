---
import { Demo, ShowcaseTabs } from '@typo/ui'

const { tr } = Astro.locals

const tabs = [
  tr('demo.cases.default.title'),
  tr('demo.cases.polish.title'),
  tr('demo.cases.japanese.title'),
]

const cases = [
  {
    initialText: 'i thinks we should definitly ship the update by tomorow, their are no blockers left',
    resolvedText: 'I think we should definitely ship the update by tomorrow — there are no blockers left.',
  },
  {
    command: '/p',
    initialText: '/p 看看今天的黄金价格',
    resolvedText: '今天的黄金价格是每克...',
  },
  {
    command: '/jp',
    initialText: '/jp 你好阿',
    resolvedText: 'こんにちは',
  },
]
---

<section class="border-y border-zinc-200 py-12 sm:py-16 lg:py-20 dark:border-zinc-800">
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500 dark:text-zinc-400">
        {tr('demo.tag')}
      </p>
      <h2 class="mt-3 text-2xl font-bold tracking-tight text-zinc-900 sm:text-3xl lg:text-4xl dark:text-zinc-50">
        {tr('demo.title')}
      </h2>
      <p class="mt-3 text-pretty text-sm leading-relaxed text-zinc-600 sm:text-base dark:text-zinc-400">
        {tr('demo.description')}
      </p>
    </div>

    <div id="showcases-root" class="mt-10 sm:mt-12">
      <div class="flex justify-center mb-8">
        <ShowcaseTabs client:load tabs={tabs} id="showcase-tabs" />
      </div>

      <div class="swiper overflow-hidden rounded-2xl border border-zinc-200/80 bg-zinc-900 shadow-sm dark:border-zinc-800">
        <div class="swiper-wrapper">
          {
            cases.map((item, index) => (
              <div class="swiper-slide p-5 sm:p-8">
                <div class="mx-auto max-w-3xl h-[280px]">
                  <Demo 
                    client:load 
                    initialText={item.initialText} 
                    resolvedText={item.resolvedText} 
                    command={item.command}
                    data-index={index}
                  />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from 'swiper'
  import { Navigation, Pagination, EffectFade } from 'swiper/modules'
  import 'swiper/css'
  import 'swiper/css/effect-fade'

  const swiper = new Swiper('.swiper', {
    modules: [EffectFade],
    effect: 'fade',
    allowTouchMove: false, // Control via tabs
    on: {
      slideChange: (s) => {
        const tabs = document.querySelector('#showcase-tabs') as any
        if (tabs?.__vue_app__) {
          // This is a hacky way to sync if we don't have a shared store
          // Better to use a custom event or a store
          window.dispatchEvent(new CustomEvent('showcase-slide-change', { detail: s.activeIndex }))
        }
      }
    }
  })

  // Listen for tab changes
  window.addEventListener('showcase-tab-change', (e: any) => {
    swiper.slideTo(e.detail)
  })
</script>

<style is:global>
  .swiper-slide {
    opacity: 0 !important;
    transition: opacity 0.3s ease;
  }
  .swiper-slide-active {
    opacity: 1 !important;
  }
</style>
