---
import Demo from '@/components/Demo.vue'
import 'swiper/css'
import 'swiper/css/effect-fade'

const { tr } = Astro.locals

const cases = [
  {
    title: tr('demo.cases.default.title'),
    description: tr('demo.cases.default.description'),
    initialText: 'i thinks we should definitly ship the update by tomorow, their are no blockers left',
    resolvedText: 'I think we should definitely ship the update by tomorrow — there are no blockers left.',
  },
  {
    title: tr('demo.cases.polish.title'),
    description: tr('demo.cases.polish.description'),
    command: '/p',
    initialText: '/p 看看今天的黄金价格',
    resolvedText: '今天的黄金价格是每克...',
  },
  {
    title: tr('demo.cases.japanese.title'),
    description: tr('demo.cases.japanese.description'),
    command: '/jp',
    initialText: '/jp 你好阿',
    resolvedText: 'こんにちは',
  },
]
---

<div
  id="showcases-root"
  class="grid gap-6 lg:grid-cols-[minmax(0,20rem)_minmax(0,1fr)] lg:items-start lg:gap-8 xl:grid-cols-[minmax(0,22rem)_minmax(0,1fr)] xl:gap-10"
>
  <div
    id="showcase-cases"
    class="no-scrollbar order-2 flex snap-x snap-mandatory gap-3 overflow-x-auto pb-1 lg:order-1 lg:snap-none lg:flex-col lg:overflow-visible lg:pb-0 lg:sticky lg:top-[calc(var(--site-header-height)+1.5rem)]"
    role="tablist"
  >
    {
      cases.map((item, index) => (
        <button
          type="button"
          role="tab"
          data-index={index}
          aria-selected={index === 0}
          class="showcase-case group relative w-[min(85vw,20rem)] shrink-0 snap-start overflow-hidden rounded-xl border border-zinc-200 bg-white p-4 text-left transition hover:border-zinc-300 lg:w-full dark:border-zinc-800 dark:bg-zinc-900/40 dark:hover:border-zinc-700"
        >
          <div class="flex items-center justify-between gap-3">
            <h3 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">{item.title}</h3>
            <span class="showcase-countdown text-xs font-medium tabular-nums text-indigo-500 dark:text-indigo-400" aria-live="polite" />
          </div>
          <p class="mt-1.5 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">{item.description}</p>
          <span class="showcase-progress absolute inset-x-0 bottom-0 h-0.5 w-0 bg-indigo-500 dark:bg-indigo-400" />
        </button>
      ))
    }
  </div>

  <div
    id="showcase-swiper"
    class="showcase-swiper swiper order-1 overflow-hidden rounded-2xl border border-zinc-200/80 bg-zinc-900 shadow-sm lg:order-2 dark:border-zinc-800"
  >
    <div class="swiper-wrapper">
      {
        cases.map((item, index) => (
          <div class="swiper-slide p-4 sm:p-6 lg:p-8">
            <div class="h-[min(400px,62vw)] min-h-[280px] sm:h-[400px]">
              <Demo
                client:load
                initialText={item.initialText}
                resolvedText={item.resolvedText}
                command={item.command}
                slideIndex={index}
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  import Swiper from 'swiper'
  import { EffectFade } from 'swiper/modules'

  const COUNTDOWN_MS = 4000
  const NEXT_LABEL = 'Next in {s}s'

  const caseButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('#showcase-cases .showcase-case'))
  const progressBars = Array.from(document.querySelectorAll<HTMLElement>('#showcase-cases .showcase-progress'))
  const countdownLabels = Array.from(document.querySelectorAll<HTMLElement>('#showcase-cases .showcase-countdown'))
  const total = caseButtons.length

  let activeIndex = 0
  let countdownRaf = 0

  function resetCountdownUi() {
    progressBars.forEach((bar) => {
      bar.style.width = '0%'
    })
    countdownLabels.forEach((label) => {
      label.textContent = ''
    })
  }

  function cancelCountdown() {
    if (countdownRaf) {
      cancelAnimationFrame(countdownRaf)
      countdownRaf = 0
    }
    resetCountdownUi()
  }

  function setActiveTab(index: number) {
    activeIndex = index
    caseButtons.forEach((btn) => {
      btn.setAttribute('aria-selected', String(Number(btn.dataset.index) === index))
    })
  }

  function notifyShowcaseSlide(index: number) {
    window.dispatchEvent(new CustomEvent('typo-showcase-slide', { detail: index }))
  }

  const swiper = new Swiper('#showcase-swiper', {
    modules: [EffectFade],
    effect: 'fade',
    allowTouchMove: false,
    on: {
      slideChange: (s) => {
        cancelCountdown()
        setActiveTab(s.activeIndex)
        notifyShowcaseSlide(s.activeIndex)
      },
    },
  })

  function startCountdown(index: number) {
    cancelCountdown()
    const bar = progressBars[index]
    const label = countdownLabels[index]
    const start = performance.now()

    const tick = (now: number) => {
      const elapsed = now - start
      const ratio = Math.min(elapsed / COUNTDOWN_MS, 1)

      if (bar)
        bar.style.width = `${ratio * 100}%`
      if (label) {
        const remaining = Math.ceil((COUNTDOWN_MS - elapsed) / 1000)
        label.textContent = remaining > 0 ? NEXT_LABEL.replace('{s}', String(remaining)) : ''
      }

      if (ratio >= 1) {
        countdownRaf = 0
        swiper.slideTo((index + 1) % total)
        return
      }

      countdownRaf = requestAnimationFrame(tick)
    }

    countdownRaf = requestAnimationFrame(tick)
  }

  window.addEventListener('typo-showcase-finished', (event) => {
    const index = (event as CustomEvent<number>).detail
    if (index === activeIndex)
      startCountdown(index)
  })

  caseButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const index = Number(btn.dataset.index)
      cancelCountdown()
      swiper.slideTo(index)
      setActiveTab(index)
    })
  })
</script>

<style>
  .showcase-case {
    cursor: pointer;
  }

  .showcase-case[aria-selected='true'] {
    border-color: rgb(129 140 248);
    box-shadow: 0 0 0 1px rgb(129 140 248 / 40%);
  }

  .showcase-progress {
    transition: width 0.08s linear;
  }
</style>

<style is:global>
  #showcase-swiper .swiper-wrapper {
    display: grid;
    height: auto;
  }

  #showcase-swiper .swiper-slide {
    grid-area: 1 / 1;
    width: 100%;
    height: auto;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  #showcase-swiper .swiper-slide-active {
    opacity: 1;
  }
</style>
