---
import { Demo } from '@typo/ui'

const { tr } = Astro.locals

const labels = {
  inputLabel: tr('demo.input_label'),
  replayLabel: tr('demo.replay_label'),
}

const cases: Array<{
  title: string
  description: string
  command?: string
  inputText: string
  outputText: string
}> = [
  {
    title: tr('demo.cases.default.title'),
    description: tr('demo.cases.default.description'),
    inputText: 'i thinks we should definitly ship the update by tomorow, their are no blockers left',
    outputText: 'I think we should definitely ship the update by tomorrow — there are no blockers left.',
  },
  {
    title: tr('demo.cases.polish.title'),
    description: tr('demo.cases.polish.description'),
    command: '/p',
    inputText: 'hey can u send me the report asap, kinda need it now',
    outputText: 'Hi, could you please send over the report at your earliest convenience? I need it fairly urgently. Thank you.',
  },
  {
    title: tr('demo.cases.japanese.title'),
    description: tr('demo.cases.japanese.description'),
    command: '/jp',
    inputText: 'Thanks so much for your help today, I really appreciate it.',
    outputText: '本日は大変お世話になり、誠にありがとうございました。',
  },
] 
---

<section class="border-y border-zinc-200 py-12 sm:py-16 lg:py-20 dark:border-zinc-800">
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500 dark:text-zinc-400">
        {tr('demo.tag')}
      </p>
      <h2 class="mt-3 text-2xl font-bold tracking-tight text-zinc-900 sm:text-3xl lg:text-4xl dark:text-zinc-50">
        {tr('demo.title')}
      </h2>
      <p class="mt-3 text-pretty text-sm leading-relaxed text-zinc-600 sm:text-base dark:text-zinc-400">
        {tr('demo.description')}
      </p>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-6 sm:mt-12 lg:grid-cols-3 lg:gap-5">
      {
        cases.map(item => (
          <article class="flex flex-col gap-4 rounded-2xl border border-zinc-200/80 bg-zinc-900 p-5 shadow-sm dark:border-zinc-800 sm:p-6">
            <div>
              <h3 class="text-base font-semibold text-zinc-50 sm:text-lg">{item.title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-zinc-400">{item.description}</p>
            </div>
            <Demo
              client:visible
              command={item.command}
              inputText={item.inputText}
              outputText={item.outputText}
              {...labels}
            />
          </article>
        ))
      }
    </div>
  </div>
</section>
