---
import Showcases from '@/components/Showcases.astro'
import { getLocalizedPath } from '@/lib/i18n'

const { locale, tr } = Astro.locals
---

<section class="pb-10 pt-8 sm:pb-16 sm:pt-10">
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="flex flex-col items-center gap-8 text-center sm:gap-10">
      <div
        class="inline-flex items-center gap-2 rounded-full border border-yellow-200 bg-yellow-50/70 px-3 py-1 text-xs font-medium text-yellow-700 dark:border-yellow-700/50 dark:bg-yellow-900/20 dark:text-yellow-200"
      >
        <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-yellow-400 dark:bg-yellow-300" aria-hidden></span>
        {tr('hero.badge')}
      </div>
      <div class="space-y-4">
        <h1 class="text-balance text-4xl font-bold tracking-tight text-zinc-900 sm:text-5xl dark:text-zinc-50">
          {tr('hero.title')}
        </h1>
        <p class="mx-auto max-w-2xl text-pretty text-lg text-zinc-600 dark:text-zinc-400">
          {tr('hero.description')}
        </p>
      </div>
    </div>
  </div>

  <div class="relative mt-10 w-full sm:mt-12 lg:mt-14">
    <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:max-w-352 lg:px-8 xl:px-10">
      <Showcases />
    </div>
  </div>

  <div class="mx-auto mt-8 flex max-w-5xl justify-center px-4 sm:mt-10 sm:px-6">
    <a
      href={getLocalizedPath('/downloads', locale)}
      class="inline-flex h-10 items-center justify-center rounded-lg bg-zinc-900 px-5 text-sm font-semibold text-white shadow-sm transition hover:bg-zinc-800 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-200"
    >
      {tr('demo.download_free')}
    </a>
  </div>
</section>
