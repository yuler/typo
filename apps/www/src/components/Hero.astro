---
import { getLocalizedPath, getLocale } from '@/lib/i18n'

const { t } = Astro.locals
const locale = getLocale(Astro.currentLocale)
---

<section class="mx-auto max-w-5xl px-4 pb-16 pt-12 sm:px-6 sm:pt-16">
  <div class="flex flex-col items-center gap-8 text-center sm:gap-10">
    <div
      class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-zinc-50 px-3 py-1 text-xs font-medium text-zinc-900 dark:border-zinc-800 dark:bg-zinc-900/50 dark:text-zinc-100"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-zinc-400 dark:bg-zinc-500" aria-hidden></span>
      {t('hero.badge')}
    </div>
    <div class="space-y-4">
      <h1 class="text-balance text-4xl font-bold tracking-tight text-zinc-900 sm:text-5xl dark:text-zinc-50">
        {t('hero.title')}
      </h1>
      <p class="mx-auto max-w-2xl text-pretty text-lg text-zinc-600 dark:text-zinc-400">
        {t('hero.description')}
      </p>
    </div>
    <div class="flex flex-col items-center gap-3 sm:flex-row">
      <a
        href={getLocalizedPath('/downloads', locale)}
        class="inline-flex h-11 items-center justify-center rounded-lg bg-zinc-900 px-6 text-sm font-semibold text-white shadow-sm transition hover:bg-zinc-800 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-200"
      >
        {t('hero.download')}
      </a>
      <a
        href={getLocalizedPath('/docs/getting-started', locale)}
        class="inline-flex h-11 items-center justify-center rounded-lg border border-zinc-300 bg-white px-6 text-sm font-semibold text-zinc-900 transition hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100 dark:hover:bg-zinc-900"
      >
        {t('hero.docs')}
      </a>
    </div>
    <figure class="mt-2 w-full max-w-3xl">
      <video
        src="https://github.com/user-attachments/assets/fd2ff3f3-ea57-4ab9-934f-b9a92c5c5b0e"
        controls
        playsinline
        preload="metadata"
        class="aspect-video w-full rounded-2xl bg-zinc-950 shadow-lg ring-1 ring-zinc-900/5 dark:ring-white/10"
      >
        {t('hero.video_fallback')}
      </video>
      <figcaption class="mt-3 text-center text-xs text-zinc-500 dark:text-zinc-500">
        {t('hero.video_caption')}
      </figcaption>
    </figure>
  </div>
</section>
