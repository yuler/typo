---

<div
  id={versionAnchorId}
  class="relative pl-10 pt-6 pb-16 group scroll-mt-24 rounded-2xl px-4 transition-all duration-300 [&:target]:bg-zinc-100 dark:[&:target]:bg-zinc-900/60 [&:target]:ring-1 [&:target]:ring-zinc-300/80 dark:[&:target]:ring-zinc-700"
>
  <!-- Timeline line -->
  <div
    class="absolute left-0 top-1 bottom-0 w-px bg-zinc-200 dark:bg-zinc-800 group-last:bg-transparent"
    aria-hidden="true"
  >
    <div
      class={`absolute inset-0 bg-gradient-to-b ${isLatest ? 'from-zinc-400 dark:from-zinc-500' : 'from-zinc-200 dark:from-zinc-700'} to-transparent`}
    >
    </div>
  </div>

  <!-- Timeline dot -->
  <div
    class={`absolute left-[-5px] top-1.5 h-2.5 w-2.5 rounded-full border-2 border-white dark:border-zinc-950 transition-all duration-300 group-hover:scale-125 group-hover:ring-4 ${isLatest ? 'bg-zinc-900 dark:bg-zinc-100 ring-zinc-100 dark:ring-zinc-800/50' : 'bg-zinc-300 dark:bg-zinc-600 group-hover:bg-zinc-900 dark:group-hover:bg-zinc-100 group-hover:ring-zinc-100 dark:group-hover:ring-zinc-800/50'}`}
    aria-hidden="true"
  >
  </div>

  <div class="flex flex-col gap-2">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
      <h2 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50 leading-none flex items-center">
        v{release.version}
        {
          isLatest && (
            <span class="ml-3 inline-flex items-center rounded-full bg-zinc-900 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-zinc-50 shadow-sm transition-all duration-300 group-hover:scale-105 dark:bg-zinc-100 dark:text-zinc-900">
              {t('page.releases.latest')}
            </span>
          )
        }
      </h2>
      <time
        class="text-xs text-zinc-500 dark:text-zinc-400 font-medium px-3 py-1 rounded-full bg-zinc-100/80 dark:bg-zinc-800/40 border border-zinc-200/50 dark:border-zinc-700/50 transition-colors group-hover:text-zinc-900 dark:group-hover:text-zinc-200"
      >
        {formatDateLong(new Date(release.date), locale)}
      </time>
    </div>

    <div class="mt-2 prose prose-zinc dark:prose-invert prose-sm max-w-none">
      <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed whitespace-pre-line text-base/relaxed">
        {notes}
      </p>
    </div>

    <div class="mt-6 flex flex-wrap gap-4">
      {
        release.assets.map((asset) => (
          <a
            href={getAssetUrl(release.version, asset.name)}
            class="flex items-center gap-4 rounded-2xl border border-zinc-200 bg-white p-3 pr-4 text-sm font-medium text-zinc-900 shadow-sm transition-all hover:bg-zinc-50 hover:border-zinc-300 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-100 dark:hover:bg-zinc-800 dark:hover:border-zinc-700"
          >
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400">
              <Fragment set:html={platformIcons[asset.platform]} />
            </div>
            <div class="flex flex-col min-w-0">
              <span class="capitalize leading-tight">{t(`page.downloads.platform.${asset.platform}`)}</span>
              <span
                class="text-[11px] text-zinc-500 font-normal truncate max-w-[120px] sm:max-w-none"
                title={asset.name}
              >
                {asset.name.split('_').pop()}
              </span>
            </div>
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-4 h-4 ml-2 text-zinc-300 dark:text-zinc-600 group-hover:text-zinc-900 dark:group-hover:text-zinc-200 transition-colors"
            >
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
          </a>
        ))
      }
    </div>
  </div>
</div>
