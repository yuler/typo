547 0 .975-.177 1.328-.355c.385-.183.699-.448.989-.536h.005c.62-.177 1.115-.537 1.391-.933zm2.917 11.944c.052.801.459 1.661 1.177 1.837c.781.177 1.911-.443 2.385-1.02l.281-.011c.421-.011.771.011 1.129.355l.005.005c.276.265.407.708.521 1.167c.115.536.203 1.041.547 1.421c.645.703.859 1.208.849 1.521c-.021.348-.251.525-.667.791c-.839.537-2.328.948-3.276 2.095c-.824.984-1.828 1.52-2.715 1.588c-.885.073-1.651-.265-2.099-1.197l-.005-.005c-.281-.532-.161-1.365.073-2.251c.235-.891.573-1.796.62-2.531c.047-.953.099-1.781.255-2.423c.161-.62.412-1.063.86-1.307l.057-.032zm-14.422.067h.016q.109-.002.208.021c.5.073.943.443 1.365 1L10.281 25l.005.005c.323.708 1.005 1.416 1.583 2.183c.579.796 1.027 1.509.975 2.093v.011c-.079.989-.641 1.525-1.5 1.724c-.86.177-2.027 0-3.193-.62c-1.291-.713-2.828-.625-3.812-.803c-.489-.088-.812-.271-.964-.536c-.145-.265-.151-.803.167-1.641v-.004c.156-.448.043-1.005-.036-1.495c-.073-.532-.109-.944.057-1.251c.213-.448.531-.531.921-.713c.391-.177.855-.265 1.219-.625h.005v-.005c.339-.353.595-.796.891-1.115c.251-.271.505-.448.88-.448m9.548-12.099c-.579.265-1.261.713-1.985.713s-1.292-.353-1.703-.62c-.208-.181-.375-.359-.5-.448c-.219-.176-.193-.447-.099-.447c.145.02.172.181.265.271c.131.088.287.265.479.443c.391.265.912.624 1.557.624c.647 0 1.407-.359 1.865-.624c.26-.177.593-.443.864-.62c.208-.183.199-.36.369-.36c.172.021.048.177-.192.443c-.245.183-.62.448-.921.625zm-1.443-2.114v-.025c-.005-.027.015-.057.041-.068c.093-.057.239-.037.344.005c.083 0 .213.088.203.181c-.011.063-.115.089-.183.089c-.072 0-.125-.057-.187-.093c-.068-.021-.199-.011-.219-.089zm-.735 0c-.027.079-.152.068-.219.089c-.063.036-.115.093-.188.093c-.068 0-.177-.027-.183-.093c-.009-.089.115-.177.199-.177c.109-.043.244-.063.348-.005c.021.011.048.041.037.068v.025z"/></svg>',
}

const platforms = ['macos', 'windows', 'linux'] as const
const assetsByPlatform = platforms.reduce(
  (acc, p) => {
    acc[p] = latestRelease.assets.filter((a) => a.platform === p)
    return acc
  },
  {} as Record<string, typeof latestRelease.assets>,
)
---

<BaseLayout title={t('page.downloads.title')} description={t('page.downloads.description')}>
  <header
    class="relative isolate overflow-hidden border-b border-zinc-200/90 bg-zinc-200/45 px-4 pb-20 pt-14 backdrop-blur-xl dark:border-zinc-800/80 dark:bg-zinc-900/35 sm:px-6 sm:pb-24 sm:pt-16 lg:pb-32 lg:pt-20"
  >
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div
        class="absolute -left-32 top-1/2 h-[22rem] w-[22rem] -translate-y-1/2 rounded-full bg-zinc-300/70 blur-[100px] dark:bg-zinc-600/35"
      >
      </div>
      <div class="absolute -right-24 -top-8 h-80 w-80 rounded-full bg-white/75 blur-[72px] dark:bg-zinc-500/25"></div>
      <div
        class="absolute left-1/2 top-0 h-72 w-[28rem] -translate-x-1/2 rounded-full bg-zinc-100/80 blur-[64px] dark:bg-zinc-800/30"
      >
      </div>
      <div
        class="absolute inset-0 bg-gradient-to-b from-white/30 via-transparent to-zinc-200/30 backdrop-blur-[2px] dark:from-zinc-950/20 dark:via-transparent dark:to-zinc-950/40 dark:backdrop-blur-sm"
      >
      </div>
    </div>

    <div class="relative mx-auto max-w-2xl text-center lg:max-w-3xl">
      <p class="font-mono text-xs font-medium uppercase tracking-[0.2em] text-zinc-500 dark:text-zinc-500">
        {t('page.downloads.tag')}
      </p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-zinc-900 sm:text-6xl dark:text-white">
        {t('page.downloads.heading')}
      </h1>

      {/* Primary Detection Section */}
      <div id="detection-area" class="mx-auto mt-12 w-full max-w-md">
        <div
          class="flex flex-col items-center gap-6 rounded-3xl border border-zinc-200 bg-white/60 p-10 text-center dark:border-zinc-700/50 dark:bg-zinc-900/60 shadow-2xl shadow-zinc-200/50 dark:shadow-none backdrop-blur-md transition-all hover:scale-[1.01]"
        >
          <div id="detected-icon" class="text-zinc-300 dark:text-zinc-700">
            <svg class="h-16 w-16 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
          </div>
          <div class="space-y-1">
            <h2 id="detected-label" class="text-2xl font-bold text-zinc-900 dark:text-zinc-50">
              {t('page.downloads.platform.detecting')}
            </h2>
            <p class="text-sm font-medium text-zinc-500 dark:text-zinc-400">
              v{latestRelease.version} — {latestRelease.date}
            </p>
          </div>
          <a
            id="download-button"
            href="#"
            class="hidden w-full items-center justify-center gap-3 rounded-2xl bg-zinc-900 px-8 py-5 text-lg font-bold text-white shadow-xl transition-all hover:bg-zinc-800 hover:scale-[1.02] active:scale-[0.98] dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-200"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5"
            >
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span id="button-text">Download</span>
          </a>
        </div>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-16">
    {/* Manual Downloads Grid */}
    <div class="mt-32">
      <div class="mb-12 flex items-center justify-between border-b border-zinc-200 pb-6 dark:border-zinc-800">
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-50">{t('page.downloads.other_platforms')}</h2>
        <span
          class="text-xs font-medium text-zinc-500 bg-zinc-100 px-3 py-1 rounded-full border border-zinc-200 dark:bg-zinc-800 dark:text-zinc-400 dark:border-zinc-700"
          >v{latestRelease.version}</span
        >
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {
          platforms.map((p) => (
            <div class="flex flex-col gap-6">
              <div class="flex items-center gap-3 text-zinc-900 dark:text-zinc-50">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400">
                  <Fragment set:html={platformIcons[p]} />
                </div>
                <h3 class="text-lg font-bold capitalize">{t(`page.downloads.platform.${p}`)}</h3>
              </div>
              <div class="flex flex-col gap-3">
                {assetsByPlatform[p].map((asset) => (
                  <a
                    href={getAssetUrl(latestRelease.version, asset.name)}
                    class="group flex flex-col rounded-xl border border-zinc-200 bg-white p-4 transition-all hover:bg-zinc-50 hover:border-zinc-300 dark:border-zinc-800 dark:bg-zinc-950 dark:hover:bg-zinc-900 dark:hover:border-zinc-700"
                  >
                    <div class="flex items-center justify-between">
                      <span class="text-sm font-bold text-zinc-900 dark:text-zinc-100">
                        {asset.name
                          .split('_')
                          .pop()
                          ?.replace('.msi', '')
                          .replace('.dmg', '')
                          .replace('.deb', '')
                          .replace('.AppImage', '') || asset.name}
                      </span>
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        class="h-4 w-4 shrink-0 text-zinc-300 group-hover:text-zinc-900 dark:text-zinc-700 dark:group-hover:text-zinc-100 transition-colors"
                      >
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <polyline points="7 10 12 15 17 10" />
                        <line x1="12" y1="15" x2="12" y2="3" />
                      </svg>
                    </div>
                    <span class="mt-1 text-[11px] text-zinc-500 font-mono truncate" title={asset.name}>
                      {asset.name}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    {/* Release Navigation */}
    <div class="mt-32 flex justify-center border-t border-zinc-100 pt-20 dark:border-zinc-800/50">
      <a
        href={`/${locale}/releases`}
        class="flex items-center gap-2 rounded-2xl bg-zinc-900 px-6 py-3 text-sm font-bold text-white shadow-lg transition-all hover:bg-zinc-800 hover:scale-[1.02] active:scale-[0.98] dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-200"
      >
        <span>{t('footer.link.releases')}</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="h-4 w-4">
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </main>

  <script
    define:vars={{
      latestRelease,
      assetsByPlatform,
      translations: {
        macos: t('page.downloads.platform.macos'),
        windows: t('page.downloads.platform.windows'),
        linux: t('page.downloads.platform.linux'),
        button: t('page.downloads.download_button'),
      },
      platformIcons,
    }}
  >
    function detect() {
      const userAgent = window.navigator.userAgent.toLowerCase()
      let platform = 'macos'

      if (userAgent.includes('win')) platform = 'windows'
      else if (userAgent.includes('linux')) platform = 'linux'

      const assets = assetsByPlatform[platform] || []
      const bestAsset =
        assets.find(
          (a) =>
            (platform === 'macos' && a.name.includes('aarch64')) ||
            (platform === 'windows' && a.name.endsWith('.msi')) ||
            (platform === 'linux' && a.name.endsWith('.deb')),
        ) || assets[0]

      if (bestAsset) {
        const button = document.getElementById('download-button')
        const label = document.getElementById('detected-label')
        const iconContainer = document.getElementById('detected-icon')
        const buttonText = document.getElementById('button-text')

        label.textContent = translations[platform]
        // Note: Using getAssetUrl logic here directly since it's simple
        button.href = `https://github.com/yuler/typo/releases/download/v${latestRelease.version}/${bestAsset.name}`

        button.classList.remove('hidden')
        button.classList.add('flex')
        buttonText.textContent = translations.button.replace('{platform}', translations[platform])
        iconContainer.innerHTML = platformIcons[platform].replace('w-6 h-6', 'h-16 w-16')
        iconContainer.classList.remove('text-zinc-300', 'dark:text-zinc-700', 'animate-pulse')
        iconContainer.classList.add('text-zinc-900', 'dark:text-zinc-50')
      }
    }

    // Run detection
    detect()
  </script>
</BaseLayout>
