---
import { render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getI18nCollectionStaticPaths, getLocalizedPath } from '@/lib/i18n'
import { formatDateLong } from '@/utils/date'

export const getStaticPaths = () => getI18nCollectionStaticPaths('blog')

interface Props {
  entry: CollectionEntry<'blog'>
}

const { entry } = Astro.props
const { Content } = await render(entry)
const { locale } = Astro.locals
---

<BaseLayout title={`${entry.data.title} — typo blog`} description={entry.data.description}>
  <main class="mx-auto max-w-3xl px-4 py-10 sm:px-6 sm:py-14">
    <nav class="text-sm text-zinc-500 dark:text-zinc-400">
      <a href={getLocalizedPath('/blog', locale)} class="font-medium text-zinc-700 hover:underline dark:text-zinc-300"
        >Blog</a
      >
      <span class="mx-2" aria-hidden>/</span>
      <span class="text-zinc-600 dark:text-zinc-400">{entry.data.title}</span>
    </nav>
    <header class="mt-8 border-b border-zinc-200 pb-8 dark:border-zinc-800">
      <time class="text-sm text-zinc-500 dark:text-zinc-400" datetime={entry.data.pubDate.toISOString()}>
        {formatDateLong(entry.data.pubDate, locale)}
      </time>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50">{entry.data.title}</h1>
      <p class="mt-3 text-lg text-zinc-600 dark:text-zinc-400">{entry.data.description}</p>
    </header>
    <article class="mdx-content mt-10">
      <Content />
    </article>
  </main>
</BaseLayout>
