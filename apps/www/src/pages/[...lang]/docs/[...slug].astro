---
import { locales } from '@typo/languages'
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import DocsLayout from '@/layouts/DocsLayout.astro'
import { getLocale, getLocalizedPath } from '@/lib/i18n'

export async function getStaticPaths() {
  const entries = await getCollection('docs', ({ data }) => import.meta.env.DEV || !data.draft)
  return locales.flatMap((l) =>
    entries.map((entry) => ({
      params: { lang: l === 'en' ? undefined : l, slug: entry.id },
      props: { entry },
    })),
  )
}

interface Props {
  entry: CollectionEntry<'docs'>
}

const { entry } = Astro.props
const { Content } = await render(entry)
const currentLocale = getLocale(Astro)
---

<DocsLayout title={`${entry.data.title} — typo docs`} description={entry.data.description}>
  <nav
    class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-zinc-500 dark:text-zinc-500"
    aria-label="Breadcrumb"
  >
    <a
      href={getLocalizedPath('/docs', currentLocale)}
      class="font-medium text-zinc-600 transition hover:text-zinc-950 dark:text-zinc-400 dark:hover:text-white"
    >
      Docs
    </a>
    <span aria-hidden class="text-zinc-400 dark:text-zinc-600">›</span>
    <span class="text-zinc-700 dark:text-zinc-300">{entry.data.title}</span>
  </nav>

  <article class="mdx-content mt-8 lg:mt-10">
    <h1>{entry.data.title}</h1>
    <p class="not-prose -mt-2 mb-8 text-[15px] leading-7 text-zinc-500 dark:text-zinc-500">{entry.data.description}</p>
    <Content />
  </article>
</DocsLayout>
