---
import { getCollection, render, type CollectionEntry } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Footer from '@/components/Footer.astro'
import Header from '@/components/Header.astro'

export async function getStaticPaths() {
  const entries = await getCollection('docs', ({ data }) => import.meta.env.DEV || !data.draft)
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }))
}

interface Props {
  entry: CollectionEntry<'docs'>
}

const { entry } = Astro.props
const { Content } = await render(entry)
---

<BaseLayout title={`${entry.data.title} — typo docs`} description={entry.data.description}>
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-10 sm:px-6 sm:py-14">
    <nav class="text-sm text-zinc-500 dark:text-zinc-400">
      <a href="/docs" class="font-medium text-zinc-700 hover:underline dark:text-zinc-300">Docs</a>
      <span class="mx-2" aria-hidden>/</span>
      <span class="text-zinc-600 dark:text-zinc-400">{entry.data.title}</span>
    </nav>
    <article class="mdx-content mt-8">
      <h1>{entry.data.title}</h1>
      <Content />
    </article>
  </main>
  <Footer />
</BaseLayout>
