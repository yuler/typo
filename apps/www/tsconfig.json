{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@typo/releases": ["../../packages/releases/src/index.ts"],
      "@typo/ui": ["../../packages/ui/src/index.ts"],
      "@typo/ui/*": ["../../packages/ui/*"]
    }
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}
