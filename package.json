{
  "name": "typo",
  "type": "module",
  "version": "1.5.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "core:dev": "cd core && bin/dev",
    "core:setup": "cd core && bin/setup",
    "core:test": "cd core && bin/rails test",
    "core:test:controller": "cd core && bin/rails test:controllers",
    "core:lint": "cd core && bin/rubocop",
    "core:lint:fix": "cd core && bin/rubocop -A",
    "core:commands": "./scripts/core-commands.sh",
    "core:rails": "cd core && bin/rails",
    "core:curl-apis": "./scripts/core-curl-apis.sh",
    "desktop:dev": "pnpm --filter @typo/desktop dev",
    "desktop:dev:x11": "pnpm --filter @typo/desktop dev:x11",
    "desktop:build": "pnpm --filter @typo/desktop build",
    "desktop:preview": "pnpm --filter @typo/desktop preview",
    "desktop:tauri": "pnpm --filter @typo/desktop tauri",
    "www:dev": "pnpm --filter @typo/www dev",
    "www:build": "pnpm --filter @typo/www build",
    "www:preview": "pnpm --filter @typo/www preview",
    "www:lint": "pnpm --filter @typo/www lint",
    "www:deploy": "pnpm www:build && ./scripts/www-deploy.sh",
    "bump": "./scripts/bump.sh",
    "clean": "pnpm --filter \"./apps/**\" --filter \"./packages/**\" clean",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format:fix": "eslint --fix . && pnpm core:lint:fix",
    "languages:build": "pnpm --filter @typo/languages build",
    "languages:test": "pnpm --filter @typo/languages test",
    "releases:gen": "pnpm --filter @typo/releases gen",
    "deps:up": "npx taze -I"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@types/node": "^24.12.2",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "^6.0.3"
  }
}
